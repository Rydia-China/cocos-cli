{
    "name": "android",
    "version": "1.0.0",
    "author": "Cocos",
    "description": "Android platform plugin",
    "license": "ISC",
    "type": "commonjs",
    "contributes": {
        "builder": {
            "register": true,
            "platform": "android",
            "config": "./src/config",
            "hooks": "./src/hooks"
        },
        "pinkBuilder": {
            "platform": "android",
            "customView": "./dist/view/build-config.js",
            "customExtensionHost": "./dist/view/build-config-host.js",
            "customFields": [
                "isSoFileCompressed",
                "androidInstant",
                "apiLevel",
                "keystorePath",
                "useDebugKeystore",
                "keystorePassword",
                "keystoreAlias",
                "keystoreAliasPassword",
                "maxAspectRatio",
                "encrypted",
                "xxteaKey",
                "compressZip",
                "JobSystem"
            ],
            "doc": "./static/platform-intro/README.md",
            "card": "./static/card.png",
            "icon": "./static/icon.png"
        }
    },
    "scripts": {
        "build-view": "node scripts/build-view.js",
        "watch-view": "node scripts/build-view.js --watch"
    }
}
